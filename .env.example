# Eleve API
ELEVE_API_URL=http://0.0.0.0:8000

# OpenAI
OPENAI_API_KEY=sk-...

# JWT — mesmo secret que o dashboard Django usa para emitir tokens
JWT_SECRET=troque-por-um-secret-seguro
JWT_ALGORITHM=HS256

# Redis
REDIS_URL=redis://localhost:6379/1

# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://nicodemus:nicodemus@localhost:5432/nicodemus_db

# File storage
FILE_STORAGE_TTL=900        # 15 minutos em segundos
FILE_STORAGE_DIR=/tmp

# CORS — domínios do dashboard que podem chamar esta API
# Dev: http://localhost:3000,http://localhost:5173
# Produção: https://painel.eleve.com.br (ajustar para o domínio real)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
